# ---- App ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5174

# ---- Database ----
MONGODB_URI=mongodb://localhost:27017/nexushub

# ---- Auth ----
JWT_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- OAuth ----
# Create the provider apps:
#   Google:    https://console.cloud.google.com/apis/credentials  (OAuth 2.0 Client ID, Web)
#   Microsoft: https://entra.microsoft.com -> App registrations
#
# Register this redirect URI with BOTH providers:
#   {PUBLIC_API_URL}/api/auth/oauth/google/callback
#   {PUBLIC_API_URL}/api/auth/oauth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Public base URL of this API (used to build the redirect URI sent to providers).
PUBLIC_API_URL=http://localhost:4000
# Frontend URL the user lands on after a successful OAuth login. Tokens arrive in the URL fragment:
#   {OAUTH_SUCCESS_REDIRECT}#accessToken=...&refreshToken=...
OAUTH_SUCCESS_REDIRECT=http://localhost:5174/auth/oauth/callback
# HMAC secret for signing the OAuth state parameter (CSRF). Use a long random string.
OAUTH_STATE_SECRET=replace-me-with-a-long-random-string

# ---- Cloudflare R2 (filled in §Cloudflare) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=